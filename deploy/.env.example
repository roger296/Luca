# deploy/.env.example
# Copy this file to deploy/.env and fill in every value before deploying.
# NEVER commit deploy/.env to git — it contains secrets.

# ── Domain names ──────────────────────────────────────────────────────────────
# Your main domain for the GL web app (e.g. gl.yourdomain.com)
GL_DOMAIN=gl.yourdomain.com

# Subdomain for the MCP server — this is the URL you enter in Cowork
MCP_DOMAIN=mcp.yourdomain.com

# ── Database ──────────────────────────────────────────────────────────────────
DB_NAME=gl_ledger
DB_USER=gl_admin

# Generate a strong password: openssl rand -hex 32
# IMPORTANT: Use hex (-hex), NOT base64 (-base64). Base64 output contains / characters
# which silently break the PostgreSQL connection URL, causing ECONNREFUSED to 127.0.0.1.
DB_PASSWORD=CHANGE_ME_strong_db_password

# ── Application secrets ───────────────────────────────────────────────────────
# Generate: openssl rand -hex 48
# IMPORTANT: Use hex (-hex), NOT base64. Same reason as above.
# This secret signs the JWT tokens issued to Cowork after OAuth.
# Changing it invalidates all existing tokens (users will need to reconnect).
JWT_SECRET=CHANGE_ME_jwt_secret_at_least_32_chars

# ── MCP user identity ─────────────────────────────────────────────────────────
# The user ID that MCP tool calls run as. Use your email or a descriptive ID.
MCP_USER_ID=admin@yourdomain.com

# Tenant ID for multi-tenant setups (single user: leave as default)
MCP_TENANT_ID=default
